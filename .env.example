VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Only for npm run setup:supabase — copy env.production.template → .env.production
# SUPABASE_DB_PASSWORD=

# Optional demo account (for "Try demo" on landing + auth)
# Password must be at least 6 characters (Supabase rejects weak passwords).
# Create this user in Supabase Auth, or let the app sign up on first demo login.
VITE_DEMO_EMAIL=demo@lamaos.app
VITE_DEMO_PASSWORD=change-me-to-a-stronger-password
