VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Only for npm run setup:supabase — copy env.production.template → .env.production
# SUPABASE_DB_PASSWORD=

# Optional demo account — email is public; password is SERVER-ONLY (never VITE_).
# Set DEMO_EMAIL + DEMO_PASSWORD in Vercel (no VITE_ prefix on password).
# VITE_DEMO_EMAIL must match DEMO_EMAIL so the app can label the demo user in UI.
DEMO_EMAIL=demo@lamaos.app
# DEMO_PASSWORD=set-in-vercel-only

VITE_DEMO_EMAIL=demo@lamaos.app
