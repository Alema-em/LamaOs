# Maintainer only — production uses Vercel env vars. End users never configure Supabase.
# Run: npm run setup:supabase
# This file is separate from .env so your Lovable personal data stays untouched.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Database password from when you created the Supabase project
# (Project Settings → Database → Database password)
SUPABASE_DB_PASSWORD=your-database-password

# Optional shared demo account (server-only — add in Vercel, not in client bundle)
DEMO_EMAIL=demo@lamaos.app
DEMO_PASSWORD=your-strong-demo-password
VITE_DEMO_EMAIL=demo@lamaos.app
